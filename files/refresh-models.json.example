{
  "servers": {
    "grimoire": {
      "baseURL": "http://localhost:9001/v1",
      "api_format": "grimoire",
      "npm": "@ai-sdk/openai-compatible",
      "auth": {
        "type": "auth_json",
        "provider": "grimoire"
      }
    },
    "crofai": {
      "baseURL": "https://crof.ai/v1",
      "api_format": "crofai",
      "npm": "@ai-sdk/openai-compatible",
      "auth": {
        "type": "auth_json",
        "provider": "crofai"
      }
    },
    "commandcode": {
      "baseURL": "https://api.commandcode.ai/provider/v1",
      "api_format": "openai",
      "npm": "@ai-sdk/openai-compatible",
      "auth": {
        "type": "auth_json",
        "provider": "commandcode"
      }
    }
  }
}
