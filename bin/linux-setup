#!/usr/bin/env bash
set -euo pipefail

BASE_URL="${LINUX_SETUP_BASE_URL:-https://raw.githubusercontent.com/LPFchan/linux-setup/main}"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/linux-setup"
MANIFEST_URL="$BASE_URL/manifest.tsv"
MANIFEST_FILE="$STATE_DIR/manifest.tsv"
HASH_FILE="$STATE_DIR/installed.tsv"
FORCE=0

usage() {
    cat <<'EOF'
Usage: linux-setup [--force] <command> [module...]

Commands:
  list                 List available modules
  install [module...]  Install or update modules
  update [module...]   Alias for install
  diff [module...]     Show local diff against remote source
  doctor               Check required local tools

Environment:
  LINUX_SETUP_BASE_URL Override source URL root
EOF
}

sha256() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$1" | cut -d' ' -f1
    else
        shasum -a 256 "$1" | cut -d' ' -f1
    fi
}

expand_path() {
    case "$1" in
        '~') printf '%s\n' "$HOME" ;;
        '~/'*) printf '%s/%s\n' "$HOME" "${1:2}" ;;
        *) printf '%s\n' "$1" ;;
    esac
}

fetch_manifest() {
    mkdir -p "$STATE_DIR"
    curl -fsSL "$MANIFEST_URL" -o "$MANIFEST_FILE"
}

module_selected() {
    local module="$1"
    shift || true
    if (($# == 0)); then
        return 0
    fi
    local wanted
    for wanted in "$@"; do
        [[ "$module" == "$wanted" ]] && return 0
    done
    return 1
}

installed_hash_for() {
    local target="$1"
    [[ -f "$HASH_FILE" ]] || return 0
    while IFS=$'\t' read -r path hash; do
        [[ "$path" == "$target" ]] && printf '%s\n' "$hash" && return 0
    done < "$HASH_FILE"
}

record_hash() {
    local target="$1" hash="$2" tmp
    mkdir -p "$STATE_DIR"
    tmp=$(mktemp)
    if [[ -f "$HASH_FILE" ]]; then
        while IFS=$'\t' read -r path old_hash; do
            [[ "$path" == "$target" ]] && continue
            printf '%s\t%s\n' "$path" "$old_hash"
        done < "$HASH_FILE" > "$tmp"
    fi
    printf '%s\t%s\n' "$target" "$hash" >> "$tmp"
    mv "$tmp" "$HASH_FILE"
}

managed_header() {
    local module="$1" source="$2"
    cat <<EOF
# Managed by linux-setup
# Module: $module
# Source: https://github.com/LPFchan/linux-setup/blob/main/$source
EOF
}

install_one() {
    local module="$1" target_spec="$2" mode="$3" source="$4"
    local target dir tmp payload old_hash current_hash new_hash install_target

    target=$(expand_path "$target_spec")
    dir=$(dirname "$target")
    mkdir -p "$dir"

    tmp=$(mktemp)
    payload=$(mktemp)

    curl -fsSL "$BASE_URL/$source" -o "$payload"
    {
        managed_header "$module" "$source"
        printf '\n'
        cat "$payload"
    } > "$tmp"

    new_hash=$(sha256 "$tmp")
    old_hash=$(installed_hash_for "$target" || true)

    if [[ -f "$target" && -n "$old_hash" ]]; then
        current_hash=$(sha256 "$target")
        if [[ "$current_hash" != "$old_hash" && "$FORCE" -ne 1 ]]; then
            install_target="$target.new"
            install -m "$mode" "$tmp" "$install_target"
            echo "Local changes detected: wrote $install_target"
            rm -f "$tmp" "$payload"
            return 0
        fi
    elif [[ -f "$target" && "$FORCE" -ne 1 ]]; then
        install_target="$target.new"
        install -m "$mode" "$tmp" "$install_target"
        echo "Untracked existing file: wrote $install_target"
        rm -f "$tmp" "$payload"
        return 0
    fi

    install -m "$mode" "$tmp" "$target"
    record_hash "$target" "$new_hash"
    echo "Installed $module -> $target"
    rm -f "$tmp" "$payload"
}

cmd_list() {
    fetch_manifest
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        printf '%-14s %s\n' "$module" "$target"
    done < "$MANIFEST_FILE"
}

cmd_install() {
    fetch_manifest
    local found=0
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        if module_selected "$module" "$@"; then
            found=1
            install_one "$module" "$target" "$mode" "$source"
        fi
    done < "$MANIFEST_FILE"
    ((found == 1)) || { echo "No matching modules." >&2; exit 1; }
}

cmd_diff() {
    fetch_manifest
    local module target mode source local_path tmp payload found=0
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        module_selected "$module" "$@" || continue
        found=1
        local_path=$(expand_path "$target")
        tmp=$(mktemp)
        payload=$(mktemp)
        curl -fsSL "$BASE_URL/$source" -o "$payload"
        { managed_header "$module" "$source"; printf '\n'; cat "$payload"; } > "$tmp"
        if [[ -f "$local_path" ]]; then
            diff -u "$local_path" "$tmp" || true
        else
            echo "Missing: $local_path"
        fi
        rm -f "$tmp" "$payload"
    done < "$MANIFEST_FILE"
    ((found == 1)) || { echo "No matching modules." >&2; exit 1; }
}

cmd_doctor() {
    local missing=0 tool
    for tool in curl install diff mktemp dirname cut cat; do
        if ! command -v "$tool" >/dev/null 2>&1; then
            echo "missing: $tool"
            missing=1
        fi
    done
    if ! command -v sha256sum >/dev/null 2>&1 && ! command -v shasum >/dev/null 2>&1; then
        echo "missing: sha256sum or shasum"
        missing=1
    fi
    ((missing == 0)) && echo "ok"
    return "$missing"
}

while (($# > 0)); do
    case "$1" in
        --force) FORCE=1; shift ;;
        -h|--help) usage; exit 0 ;;
        *) break ;;
    esac
done

cmd="${1:-}"
[[ -n "$cmd" ]] || { usage; exit 1; }
shift || true

case "$cmd" in
    list) cmd_list "$@" ;;
    install|update) cmd_install "$@" ;;
    diff) cmd_diff "$@" ;;
    doctor) cmd_doctor ;;
    *) usage >&2; exit 1 ;;
esac
